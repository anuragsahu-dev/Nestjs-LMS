generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  COURSE_MANAGER
  ADMIN
  SUPER_ADMIN
}

model User {
  id String @id @default(uuid())

  // Basic Info
  name     String? @db.VarChar(100)
  email    String? @unique @db.VarChar(320)
  password String? @db.VarChar(255)
  avatar   String? @default("default-avatar.png")
  avatarId String? @db.VarChar(150)
  bio      String? @db.VarChar(300)

  // Roles
  role     Role    @default(STUDENT)
  isActive Boolean @default(true)

  // Multi-auth / Verification
  googleId        String?   @unique
  phone           String?   @unique @db.VarChar(15)
  countryCode     String?   @db.VarChar(5)
  isPhoneVerified Boolean   @default(false)
  phoneOtp        String?   @db.VarChar(10)
  phoneOtpExpire  DateTime?

  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?   @db.VarChar(100)
  emailVerificationExpire DateTime?

  // Password reset
  resetPasswordToken  String?   @db.VarChar(100)
  resetPasswordExpire DateTime?

  // Refresh Tokens / Sessions
  refreshToken String? @db.Text // allowed two devices means make table or array for that

  // Security
  failedLoginAttempts Int @default(0)

  // Activity Tracking
  lastLoginAt  DateTime?
  lastLogoutAt DateTime?
  lastActive   DateTime? @default(now())

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deActivatedAt DateTime?

  // Relations to profiles
  // studentProfile         StudentProfile?
  // teacherProfile         TeacherProfile?
  // courseManager          CourseManager?

  @@index([role])
  @@index([email])
  @@index([phone])
}

